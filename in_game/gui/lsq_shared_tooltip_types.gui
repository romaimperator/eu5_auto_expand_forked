@tooltip_inner_margin = 10
types lsq_shared_tooltip_types {
  type LSQTooltipTextBlockContainer = TooltipListBase {
    vbox = {
      layoutpolicy_horizontal = expanding
      margin = { @tooltip_inner_margin @tooltip_inner_margin }

      block "text_content" {
        LSQTooltipTextBox = {}
      }
    }
  }

  type LSQTooltipTextBox = textbox {
    using = tooltip_text_block_template

    block "text" {
      raw_text = " "
    }
  }
}
