						raw_text = "lsq_p_expensive_building_age_2_renaissance_cost_modifier: [GuiScope.SetRoot(GetPlayer.MakeScope).ScriptValue('lsq_p_expensive_building_age_2_renaissance_cost_modifier')]"
					}
				}
				TooltipTextBlock = {
					blockoverride "text" {
						raw_text = "lsq_p_expensive_building_age_3_discovery_cost_modifier: [GuiScope.SetRoot(GetPlayer.MakeScope).ScriptValue('lsq_p_expensive_building_age_3_discovery_cost_modifier')]"
					}
				}
				TooltipTextBlock = {
					blockoverride "text" {
						raw_text = "lsq_p_expensive_building_age_4_reformation_cost_modifier: [GuiScope.SetRoot(GetPlayer.MakeScope).ScriptValue('lsq_p_expensive_building_age_4_reformation_cost_modifier')]"
					}
				}
				TooltipTextBlock = {
					blockoverride "text" {
						raw_text = "lsq_p_expensive_building_age_5_absolutism_cost_modifier: [GuiScope.SetRoot(GetPlayer.MakeScope).ScriptValue('lsq_p_expensive_building_age_5_absolutism_cost_modifier')]"
					}
				}
				TooltipTextBlock = {
					blockoverride "text" {
						raw_text = "lsq_p_expensive_building_age_6_revolutions_cost_modifier: [GuiScope.SetRoot(GetPlayer.MakeScope).ScriptValue('lsq_p_expensive_building_age_6_revolutions_cost_modifier')]"
					}
				}
			}
		}

		blockoverride "tooltip_ui_action_block" {
			TooltipFunctionalBlock = {
				using = tooltip_left_right_click_template
				blockoverride "action_left_text" {
					raw_text = "Toggle Auto-Expand"
				}
				blockoverride "action_right_text" {
					raw_text = "Open Settings"
				}
			}
		}
	}
}

template lsq_Mass_Autoexpand_RGO_Tooltip {
	ContextualTooltipType = {
		name = "lsq_mass_auto_expand_rgo_tooltip"
		vbox = {
			size = { 0 0 }
			scissor = yes
			ignore_layout = yes
			ignoreinvisible = yes
			name = "lsq_auto_expand_active_rgo_locations"
			datamodel = "[ExpandRawGoodsLateralView.GetRawGoodLocationItems]"
			item = {
				overlappingitembox = {
					size = { 0 0 }
					scissor = yes
					ignore_layout = yes
					datacontext = "[RawGoodLocationItem.GetLocation]"
					visible = "[GetScriptedGui('lsq_set_auto_expand_for_rgo').IsShown(GuiScope.SetRoot(Location.MakeScope).End)]"
					# text_single = { raw_text = "bye" }
				}
			}
		}
		vbox = {
			size = { 0 0 }
			scissor = yes
			ignore_layout = yes
			ignoreinvisible = yes
			name = "lsq_auto_expand_possible_rgo_locations"
			datamodel = "[ExpandRawGoodsLateralView.GetRawGoodLocationItems]"
			item = {
				overlappingitembox = {
					size = { 0 0 }
					scissor = yes
					ignore_layout = yes
					datacontext = "[RawGoodLocationItem.GetLocation]"
					visible = "[ObjectsEqual(Location.GetOwner, GetPlayer)]"
					# text_single = { raw_text = "bye" }
				}
			}
		}
		blockoverride "title_icon" {
			lsq_auto_expand_checkbutton = {
				using = tooltip_title_icon_size
				checked = "[EqualTo_int32(PdxGuiWidget.FindParent('lsq_mass_auto_expand_rgo_tooltip').FindChild('lsq_auto_expand_possible_rgo_locations').CountVisibleChildren, PdxGuiWidget.FindParent('lsq_mass_auto_expand_rgo_tooltip').FindChild('lsq_auto_expand_active_rgo_locations').CountVisibleChildren)]"
				enabled = yes
			}
		}

		blockoverride "title_text" {
			raw_text = "Mass Auto-Expand RGOs"
		}

		blockoverride "concept_link" {
			text = [resource_gathering_operations|e]
		}

		blockoverride "tooltip_content" {
			TooltipListBase = {
				blockoverride "block_title" {
					raw_text = "Click to toggle auto-expand for all locations shown below. Add or remove filters to change which locations will be affected."
				}
			}

			TooltipListBase = {
				margin = { 5 10 }
				vbox = {
					textbox = {
						using = tooltip_text_block_template
						raw_text = "Locations which can have auto-expand enabled: [PdxGuiWidget.FindParent('lsq_mass_auto_expand_rgo_tooltip').FindChild('lsq_auto_expand_possible_rgo_locations').CountVisibleChildren]"
					}
					textbox = {
						using = tooltip_text_block_template
						raw_text = "Locations with auto-expand enabled: [PdxGuiWidget.FindParent('lsq_mass_auto_expand_rgo_tooltip').FindChild('lsq_auto_expand_active_rgo_locations').CountVisibleChildren]"
					}
				}
			}
		}

		blockoverride "tooltip_ui_action_block" {
			TooltipFunctionalBlock = {
				using = tooltip_left_right_click_template
				blockoverride "action_left_text" {
					raw_text = "Toggle Auto-Expand"
				}
				blockoverride "action_right_text" {
					raw_text = "Open Settings"
				}
			}
		}
	}
}
